// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Looking for ways to speed up your queries, or scale easily with your serverless or edge functions?
// Try Prisma Accelerate: https://pris.ly/cli/accelerate-init

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model Role {
  id        Int      @id @default(autoincrement())
  name      String   @unique
  createdAt DateTime @default(now())

  users User[]
}

model User {
  id       Int     @id @default(autoincrement())
  email    String? @unique
  phone    String  @unique
  password String

  roleId Int
  role   Role @relation(fields: [roleId], references: [id])

  memberId Int?
  member   Member? @relation(fields: [memberId], references: [id])

  status Boolean @default(true)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

enum Gender {
  MALE
  FEMALE
}

enum MemberStatus {
  ACTIVE
  INACTIVE
  LEFT
  DECEASED
}

enum MaritalStatus {
  SINGLE
  MARRIED
  DIVORCED
  SEPARATED
}

enum BaptismStatus {
  BAPTIZED
  NOT_BAPTIZED
}

model Member {
  id        Int     @id @default(autoincrement())

  // Name
  firstName  String
  middleName String
  lastName   String

  // Personal
  gender    Gender?
  birthDate DateTime? @db.Date

  // Contact
  phone            String  @unique
  alternativePhone String?
  email            String?

  // Address
  city        String?
  subCity     String?
  woreda      String?
  houseNumber String?

  // Church lifecycle
  joinedDate    DateTime? @db.Date
  salvationDate DateTime? @db.Date

  // Baptism quick status
  baptismStatus BaptismStatus @default(NOT_BAPTIZED)

  // Status
  status         MemberStatus @default(ACTIVE)
  inactiveReason String?

  // Marital
  maritalStatus MaritalStatus?

  // Background
  previousChurch String?

  // Notes
  notes String?

  // Photo
  photo String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  users User[]

  foundationClasses  FoundationClassMember[]
  foundationLeaders  FoundationClassLeader[]
  foundationTeachers FoundationClassTeacher[]

  departmentMemberships DepartmentMember[]
  departmentLeaderships DepartmentLeader[]

  attendances Attendance[]
  baptisms    BaptismMember[]

  familyRelationships1 FamilyRelationship[] @relation("FamilyRelationships1")
  familyRelationships2 FamilyRelationship[] @relation("FamilyRelationships2")

  tithes Tithe[]

  @@index([status])
  @@index([phone])
  @@index([firstName, middleName, lastName])
}

// -----------------------------
// Foundation Classes
// -----------------------------
model FoundationClass {
  id        Int      @id @default(autoincrement())
  name      String   @unique
  level     Int // 1 or 2
  createdAt DateTime @default(now())

  members  FoundationClassMember[]
  leaders  FoundationClassLeader[]
  teachers FoundationClassTeacher[]
  sessions AttendanceSession[]
  tithes   Tithe[]
}

// Pivot table: member ↔ foundation class
// memberId is NOT unique — a member can have history across multiple classes
model FoundationClassMember {
  id                Int       @id @default(autoincrement())
  memberId          Int
  foundationClassId Int
  isActive          Boolean   @default(true)  // true = current class
  joinedAt          DateTime  @default(now())
  leftAt            DateTime?                 // set when transferred or removed

  member          Member          @relation(fields: [memberId], references: [id])
  foundationClass FoundationClass @relation(fields: [foundationClassId], references: [id])

  @@index([memberId])
  @@index([foundationClassId])
}

// Leaders for foundation class
model FoundationClassLeader {
  id                Int      @id @default(autoincrement())
  memberId          Int
  foundationClassId Int
  isMainLeader      Boolean  @default(false)
  assignedAt        DateTime @default(now())

  member          Member          @relation(fields: [memberId], references: [id])
  foundationClass FoundationClass @relation(fields: [foundationClassId], references: [id])

  @@unique([memberId, foundationClassId])
}

// Teachers for foundation class
model FoundationClassTeacher {
  id                Int      @id @default(autoincrement())
  memberId          Int
  foundationClassId Int
  assignedAt        DateTime @default(now())

  member          Member          @relation(fields: [memberId], references: [id])
  foundationClass FoundationClass @relation(fields: [foundationClassId], references: [id])

  @@unique([memberId, foundationClassId])
}

// -----------------------------
enum TitheType {
  NAMED
  ANONYMOUS
}

model Tithe {
  id                  Int       @id @default(autoincrement())
  amount              Decimal   @db.Decimal(10, 2)
  type                TitheType
  
  // Tithe giver info (can be from existing member or manually entered)
  memberId            Int?      // null if not linked to a member
  name                String?   // manually entered name (for non-members or quick entry)
  email               String?   // manually entered email
  phone               String?   // manually entered phone
  
  // Foundation class (optional - can be null for "No foundation class")
  foundationClassId   Int?
  
  date                DateTime
  notes               String?
  createdAt           DateTime  @default(now())

  member              Member?           @relation(fields: [memberId], references: [id], onDelete: SetNull)
  foundationClass     FoundationClass?  @relation(fields: [foundationClassId], references: [id], onDelete: SetNull)
}

// Family Relationships
// -----------------------------
enum RelationType {
  SPOUSE
  PARENT
  CHILD
  SIBLING
}

model FamilyRelationship {
  id           Int          @id @default(autoincrement())
  memberId1    Int
  memberId2    Int
  relationType RelationType
  createdAt    DateTime     @default(now())

  member1 Member @relation("FamilyRelationships1", fields: [memberId1], references: [id], onDelete: Cascade)
  member2 Member @relation("FamilyRelationships2", fields: [memberId2], references: [id], onDelete: Cascade)

  @@unique([memberId1, memberId2])
  @@index([memberId1])
  @@index([memberId2])
}

// -----------------------------
// Baptism
// -----------------------------
model BaptismRound {
  id        Int      @id @default(autoincrement())
  name      String   @unique // e.g., "First Round 2026", "Second Round 2026"
  date      DateTime
  notes     String?
  createdAt DateTime @default(now())

  members BaptismMember[]
}

model BaptismMember {
  id             Int      @id @default(autoincrement())
  memberId       Int
  baptismRoundId Int
  baptizedAt     DateTime @default(now())

  member        Member        @relation(fields: [memberId], references: [id])
  baptismRound  BaptismRound  @relation(fields: [baptismRoundId], references: [id])

  @@unique([memberId, baptismRoundId])
}

// Departments
// -----------------------------
model Department {
  id        Int      @id @default(autoincrement())
  name      String   @unique
  createdAt DateTime @default(now())

  members DepartmentMember[]
  leaders DepartmentLeader[]
}

// Pivot table: member ↔ department
model DepartmentMember {
  id           Int      @id @default(autoincrement())
  memberId     Int
  departmentId Int
  joinedAt     DateTime @default(now())

  member     Member     @relation(fields: [memberId], references: [id])
  department Department @relation(fields: [departmentId], references: [id])

  @@unique([memberId, departmentId])
}

// Leaders for department
model DepartmentLeader {
  id           Int      @id @default(autoincrement())
  memberId     Int
  departmentId Int
  assignedAt   DateTime @default(now())

  member     Member     @relation(fields: [memberId], references: [id])
  department Department @relation(fields: [departmentId], references: [id])

  @@unique([memberId, departmentId])
}

// -----------------------------
// Attendance
// -----------------------------
model AttendanceSession {
  id                Int      @id @default(autoincrement())
  foundationClassId Int
  sessionDate       DateTime
  notes             String?
  createdAt         DateTime @default(now())

  foundationClass FoundationClass @relation(fields: [foundationClassId], references: [id])
  attendances     Attendance[]
}

model Attendance {
  id                  Int      @id @default(autoincrement())
  attendanceSessionId Int
  memberId            Int
  present             Boolean  @default(false)
  recordedAt          DateTime @default(now())

  member  Member            @relation(fields: [memberId], references: [id])
  session AttendanceSession @relation(fields: [attendanceSessionId], references: [id])

  @@unique([attendanceSessionId, memberId])
}
